<UserControl x:Class="Duru.WPF.Views.EmployeeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Title="Employee Management">
    <Grid>
        <StackPanel>
            <TextBlock Text="Employee Management" FontSize="24" FontWeight="Bold"/>
            <TextBox Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Search Employees"/>
            <ListBox ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding FullName}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Button Content="Add Employee" Command="{Binding AddEmployeeCommand}"/>
            <Button Content="Edit Employee" Command="{Binding EditEmployeeCommand}" IsEnabled="{Binding SelectedEmployee}"/>
            <Button Content="Delete Employee" Command="{Binding DeleteEmployeeCommand}" IsEnabled="{Binding SelectedEmployee}"/>
            <Button Content="Save" Command="{Binding SaveEmployeeCommand}" IsEnabled="{Binding IsEditing}"/>
            <Button Content="Cancel" Command="{Binding CancelEditCommand}" IsEnabled="{Binding IsEditing}"/>
            <ProgressBar IsIndeterminate="True" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
    </UserControl>