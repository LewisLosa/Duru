<Window x:Class="Duru.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Duru.WPF"
        xmlns:views="clr-namespace:Duru.WPF.Views"
        xmlns:vm="clr-namespace:Duru.WPF.ViewModels"
        mc:Ignorable="d"
        Title="Duru Hotel Management System" Height="650" Width="1000">
    <Grid>
        <ContentControl x:Name="ViewHost" Content="{Binding CurrentViewModel}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:LoginViewModel}">
                    <views:LoginView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                    <views:DashboardView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:EmployeeManagementViewModel}">
                    <views:EmployeeManagementView />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>