<Page x:Class="Duru.App.Views.LoginView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:viewmodels="clr-namespace:Duru.App.ViewModels"
      d:DataContext="{d:DesignInstance Type=viewmodels:LoginViewModel}"
      mc:Ignorable="d" 
      Title="Login">

    <Grid Background="#f5f5f5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1e88e5" Height="80">
            <TextBlock Text="Duru Hotel Management System" 
                       FontSize="24" 
                       Foreground="White" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Login Form -->
        <Border Grid.Row="1" 
                Width="400" 
                Height="450" 
                Background="White" 
                CornerRadius="8" 
                Margin="0,30,0,0"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                BorderBrush="#ddd"
                BorderThickness="1"
                Padding="30">
            <StackPanel>
                <TextBlock Text="Login" 
                           FontSize="22" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Center" 
                           Margin="0,10,0,30"/>

                <!-- Error Message -->
                <Border Background="#ffebee" 
                        CornerRadius="4" 
                        Padding="10" 
                        Margin="0,0,0,20" 
                        Visibility="{Binding ErrorMessage}">
                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="#c62828" 
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Username -->
                <TextBlock Text="Username" 
                           Margin="0,0,0,5"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="10" 
                         Margin="0,0,0,15"/>

                <!-- Password -->
                <TextBlock Text="Password" 
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" 
                             Padding="10" 
                             Margin="0,0,0,15"/>

                <!-- Remember Me -->
                <CheckBox Content="Remember me" 
                          IsChecked="{Binding RememberMe}" 
                          Margin="0,0,0,20"/>

                <!-- Login Button -->
                <Button Content="LOGIN" 
                        Command="{Binding LoginCommand}" 
                        Background="#1e88e5" 
                        Foreground="White" 
                        Padding="15,8" 
                        Margin="0,10,0,0"
                        IsEnabled="{Binding IsBusy}"/>

                <!-- Forgot Password -->
                <Button Content="Forgot Password?" 
                        Command="{Binding ForgotPasswordCommand}" 
                        Background="Transparent" 
                        Foreground="#1e88e5" 
                        BorderThickness="0" 
                        HorizontalAlignment="Center" 
                        Margin="0,20,0,0"/>

                <!-- Loading Indicator -->
                <ProgressBar IsIndeterminate="True" 
                             Height="4" 
                             Margin="0,20,0,0" 
                             Visibility="{Binding IsBusy}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>